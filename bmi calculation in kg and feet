print("*" * 20)
Name= input("what is your name?\n")
Weight= float(input("what is your weight?"' ENTER YOUR WEIGHT IN KG! \n'))  #enter your weight in it
Height_in_feets= float(input("what is your height?" 'ENTER YOUR HEIGHT IN Feets\n'))#enter height bcz for bmi you need weight and height both
